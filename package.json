  "description": "Seu parceiro financeiro que fala sua língua — Personal Financial Assistant for Brazilians",
  "main": "./out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "postinstall": "electron-builder install-app-deps",
    "lint": "eslint . --ext .ts,.tsx",
    "typecheck": "tsc --noEmit",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio",
    "test": "vitest run",
    "test:watch": "vitest",
    "build:mac": "electron-vite build && electron-builder --mac",
    "build:win": "electron-vite build && electron-builder --win",
    "build:linux": "electron-vite build && electron-builder --linux"
  },
  "repository": {
    "type": "git",
    "url": "http://local_proxy@127.0.0.1:35181/git/duboc/desenrola"
  },
  "keywords": ["finance", "brazil", "electron", "personal-finance", "desenrola"],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@tanstack/react-query": "^5.62.0",
    "date-fns": "^4.1.0",
    "drizzle-orm": "^0.38.0",
    "better-sqlite3": "^11.7.0",
    "lucide-react": "^0.468.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-hook-form": "^7.54.0",
    "react-router-dom": "^7.1.0",
    "recharts": "^2.15.0",
    "zod": "^3.24.0",
    "zustand": "^5.0.0",
    "@hookform/resolvers": "^3.9.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
